{
  "name": "agent-hive",
  "version": "0.1.0",
  "description": "Self-hosted coding agent server — pi.dev SDK + Fastify",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./mcp": {
      "import": "./dist/mcp/server.js"
    }
  },
  "files": [
    "dist",
    "ui/dist",
    ".env.example",
    "README.md"
  ],
  "bin": {
    "hive": "dist/cli/hive.js"
  },
  "scripts": {
    "build": "npx -p typescript tsc",
    "start": "node -r dotenv/config dist/index.js",
    "mcp": "node dist/mcp/server.js",
    "telegram": "node dist/telegram/bot.js",
    "cli": "node dist/cli/hive.js",
    "dev": "tsc --watch & node --watch -r dotenv/config dist/index.js",
    "test": "npm run build && node --test \"dist/test/**/*.test.js\""
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.0",
    "@mariozechner/pi-coding-agent": "latest",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.0.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  }
}
