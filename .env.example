# Agent Hive configuration

# ── Auth ──────────────────────────────────────────────
# Single token (simplest):
API_TOKEN=your-secret-api-token-here
# Or multiple tokens with profiles (takes precedence over API_TOKEN):
# API_TOKENS={"tok-admin":{"name":"Admin","role":"admin"},"tok-bob":{"name":"Bob","role":"user"}}

# ── Git identity used for commits ─────────────────────
GIT_AUTHOR_NAME=agent-hive
GIT_AUTHOR_EMAIL=agent-hive@users.noreply.github.com

# ── LLM provider keys (BYOK; pi.dev reads standard env var names) ──
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
# Z.AI coding plan:
ZAI_CODE=
# DeepSeek (direct):
DEEPSEEK_API_KEY=

# ── Default model ─────────────────────────────────────
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-20250514
DEFAULT_THINKING=off

# ── Runtime ───────────────────────────────────────────
PORT=8080
WORKSPACE=/tmp/hive-workspace
# SQLite store location (durable task + event history):
HIVE_DB_PATH=data/hive.db
MAX_CONCURRENT_SESSIONS=3
SESSION_IDLE_TIMEOUT_MS=1800000
# Keep the cloned repo on disk after a task finishes (for inspection)
HIVE_KEEP_WORKSPACE=0
# Open a pull request with the work (default on). Set to 0 to let the agent push freely.
HIVE_OPEN_PR=1
# Override the gh binary path if needed:
# GH_BIN=gh

# Pi telemetry off
PI_TELEMETRY=0

# ── MCP / Telegram clients (separate processes that call the Hive REST API) ─
# Where the Hive server is reachable, and a valid token from API_TOKEN(S):
# HIVE_URL=http://localhost:8080
# HIVE_TOKEN=your-token
# Telegram bot (optional mobile surface):
# TELEGRAM_BOT_TOKEN=123456:ABC...
# Comma-separated chat ids allowed to drive the bot (required for it to act):
# TELEGRAM_ALLOWED_CHATS=123456789
